{
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "echo \"{\\\"hookSpecificOutput\\\": {\\\"hookEventName\\\": \\\"UserPromptSubmit\\\", \\\"additionalContext\\\": \\\"当前北京时间: $(TZ='Asia/Shanghai' date '+%Y-%m-%d %H:%M:%S')\\\"}}\""
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "python \"$CLAUDE_PROJECT_DIR/.claude/hooks/session_breath.py\"",
            "shell": "/bin/bash",
            "timeout": 12,
            "statusMessage": "Ombre Brain 正在浮现记忆..."
          }
        ]
      },
      {
        "matcher": "resume",
        "hooks": [
          {
            "type": "command",
            "command": "python \"$CLAUDE_PROJECT_DIR/.claude/hooks/session_breath.py\"",
            "shell": "/bin/bash",
            "timeout": 12,
            "statusMessage": "Ombre Brain 正在浮现记忆..."
          }
        ]
      }
    ]
  }
}
