{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 -c \"import json; from datetime import datetime; from zoneinfo import ZoneInfo; now=datetime.now(ZoneInfo('Asia/Shanghai')).strftime('%Y-%m-%d %H:%M:%S'); print(json.dumps({'hookSpecificOutput':{'hookEventName':'UserPromptSubmit','additionalContext':f'当前北京时间: {now}'}}))\"",
            "shell": "bash",
            "timeout": 5
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "python \"$CLAUDE_PROJECT_DIR/.claude/hooks/session_breath.py\"",
            "shell": "/bin/bash",
            "timeout": 12,
            "statusMessage": "Ombre Brain 正在浮现记忆..."
          }
        ]
      },
      {
        "matcher": "resume",
        "hooks": [
          {
            "type": "command",
            "command": "python \"$CLAUDE_PROJECT_DIR/.claude/hooks/session_breath.py\"",
            "shell": "/bin/bash",
            "timeout": 12,
            "statusMessage": "Ombre Brain 正在浮现记忆..."
          }
        ]
      }
    ]
  }
}
